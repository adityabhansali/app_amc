# Copy to .env and fill in real values
SECRET_KEY=change-this-to-a-long-random-string

# Public base URL — used to build shareable quotation links that are clickable
# on a client's phone / WhatsApp. Three options:
#   Same WiFi only:  BASE_URL=http://192.168.29.65:5055
#   ngrok tunnel:    BASE_URL=https://xxxx.ngrok-free.app
#   Vercel (prod):   BASE_URL=https://your-app.vercel.app
# Leave blank: the app auto-detects the LAN IP (same-WiFi only).
BASE_URL=

# Database. Local dev uses SQLite; on Vercel set a managed Postgres URL
# (e.g. Neon). "postgres://" URLs are auto-normalised to "postgresql://".
DATABASE_URL=sqlite:///nse_amc.db
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Vercel Blob (file uploads in production). Leave empty for local disk uploads.
# Get this from the Vercel dashboard: Storage > your Blob store > tokens.
BLOB_READ_WRITE_TOKEN=

# OpenRouter (AI Q&A assistant)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Company / contact details shown across the app
COMPANY_NAME=Northern Star Engineering
COMPANY_CITY=Surat, Gujarat
EMERGENCY_HOTLINE=1800-891-8565
COMPANY_PHONE=9687266625
COMPANY_EMAIL=info@northernstarengineering.com
COMPANY_ADDRESS=521-522, Western Business Park, opp. S.D. Jain School, Surat, Gujarat 395007

# UPI handle the "Pay by UPI / GPay" button on quotation links pays into.
# Leave blank to show a "UPI being set up" notice instead of a live QR.
COMPANY_UPI_ID=
COMPANY_UPI_NAME=Northern Star Engineering

# Email (Flask-Mail via Microsoft Outlook / Office 365)
# Set MAIL_PASSWORD to enable actual email sending.
# While MAIL_SUPPRESS_SEND=true, emails are logged to console only.
MAIL_PASSWORD=your-outlook-password-here
MAIL_SUPPRESS_SEND=true

# Business constants (used in quotation PDFs)
COMPANY_GST=24ALQPD0899P1ZD
SALES_MANAGER_PHONE=+919687266625
